# Public app configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_LIVE_TRADING=false

# Server-only. Never expose this key in NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Required production controls
LIVE_TRADING=false
LEGAL_APPROVAL_REFERENCE=
SIGNED_URL_TTL_SECONDS=60
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,application/pdf
COINGECKO_DEMO_API_KEY=

# Demo mode is local-only. Production validation rejects DEMO_MODE=true.
DEMO_MODE=false
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=
ALLOW_TEST_SEED=false
TEST_USER_PASSWORD=
