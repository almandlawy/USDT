# === Public ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LIVE_TRADING=false
NEXT_PUBLIC_KYC_INTAKE_ENABLED=false
NEXT_PUBLIC_PROOF_INTAKE_ENABLED=false

# === Supabase (public) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# === Supabase (server only — never NEXT_PUBLIC_*) ===
SUPABASE_SERVICE_ROLE_KEY=

# === Trading lock (must remain false in pre-launch) ===
LIVE_TRADING=false
LEGAL_APPROVAL_REFERENCE=

# === Auth / CAPTCHA ===
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Test-only bypass — ignored when VERCEL_ENV=production
TURNSTILE_BYPASS_FOR_TESTS=false
# Operational attestation that Supabase Auth email/SMTP is configured
AUTH_EMAIL_PROVIDER_CONFIGURED=

# === Security (server only) ===
SECURITY_HASH_SECRET=
INTERNAL_HEALTH_TOKEN=
CSRF_ALLOWED_HOSTS=

# === Document intake (server authoritative; default false) ===
KYC_INTAKE_ENABLED=false
PROOF_INTAKE_ENABLED=false

# === Market ===
COINGECKO_DEMO_API_KEY=
USD_TO_IQD_RATE=1310
USD_TO_AED_RATE=3.6725
MARKET_PROVIDER_TIMEOUT_MS=4000

# === Contact (optional — empty values are hidden in public UI) ===
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_PRIVACY_EMAIL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_WORKING_HOURS=
NEXT_PUBLIC_TRADE_LICENSE_NUMBER=

# === Uploads ===
SIGNED_URL_TTL_SECONDS=60
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,application/pdf

# === Monitoring (optional) ===
# SENTRY_DSN=
# COMMIT_SHA=
# BUILD_TIME=

# === E2E / QA ===
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# === Local demo / seeds (Vercel Production rejects DEMO_MODE=true) ===
DEMO_MODE=false
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=
ALLOW_TEST_SEED=false
TEST_USER_PASSWORD=
