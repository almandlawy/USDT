# === Application (public) ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LIVE_TRADING=false

# === Supabase public ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# === Supabase server only — never expose as NEXT_PUBLIC_* ===
SUPABASE_SERVICE_ROLE_KEY=

# === Trading lock (must remain false in pre-launch) ===
LIVE_TRADING=false
LEGAL_APPROVAL_REFERENCE=

# === Market data ===
COINGECKO_DEMO_API_KEY=
USD_TO_IQD_RATE=1310
USD_TO_AED_RATE=3.6725
MARKET_PROVIDER_TIMEOUT_MS=4000

# === Contact (optional — omitted values are hidden in UI) ===
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_WORKING_HOURS=
NEXT_PUBLIC_TRADE_LICENSE_NUMBER=

# === Uploads / security ===
SIGNED_URL_TTL_SECONDS=60
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,application/pdf

# === Local demo / seeds (Production rejects DEMO_MODE=true) ===
DEMO_MODE=false
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=
ALLOW_TEST_SEED=false
TEST_USER_PASSWORD=
